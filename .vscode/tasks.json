{
	// ─────────────────────────────────────────────────────────────────────────
	// Polarion Developer Tasks
	// ─────────────────────────────────────────────────────────────────────────
	// Container-Management (Build Image, Start, Stop) →  polarion-docker.code-workspace
	// ─────────────────────────────────────────────────────────────────────────
	"version": "2.0.0",
	"options": {
		"env": {
			"POLARION_CONTAINER_NAME": "polarion",
			"POLARION_EXTENSION_NAME": "custom",
			"POLARION_IMAGE": "polarion:local",
			"POLARION_HTTP_PORT": "80",
			"POLARION_DB_PORT": "5433",
			"POLARION_JDWP_PORT": "5005",
			"POLARION_BIND_HOST": "0.0.0.0",
			"POLARION_JAVA_OPTS": "-Xmx3g -Xms3g",
			"POLARION_JDWP_ENABLED": "true",
			"POLARION_PLATFORM": "linux/amd64",
			"POLARION_CONTAINER_CPUS": "8",
			"POLARION_CONTAINER_MEMORY": "4g",
			"POLARION_BUILDER_CPUS": "8",
			"POLARION_BUILDER_MEMORY": "8g",
			"POLARION_REDEPLOY_SEARCH_DEPTH": "1",
			"POLARION_DATA_VOLUME": "polarion_repo",
			"POLARION_EXTENSIONS_VOLUME": "polarion_extensions"
		},
		"cwd": "${workspaceFolder}"
	},
	"tasks": [
		// ── Kern-Tasks ───────────────────────────────────────────────────────
		{
			// Streamt das Polarion-Applikationslog live mit.
			"label": "Polarion: Logs",
			"type": "shell",
			"command": "bash",
			"args": ["scripts/polarionctl.sh", "logs"],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "new"
			},
			"problemMatcher": []
		},
		{
			// Baut das Plugin des aktuell geöffneten Files (Maven) und deployt
			// es in den laufenden Container inkl. Polarion-Service-Restart.
			"label": "Polarion: Redeploy Single",
			"type": "shell",
			"command": "bash",
			"args": ["scripts/redeploy.sh", "${file}", "polarion", "custom"],
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": []
		},
		{
			// Baut und deployt alle Plugin-Projekte im Workspace
			// (alle biz.avasis.polarion.* unterhalb von workspaceFolder).
			"label": "Polarion: Redeploy All",
			"type": "shell",
			"command": "bash",
			"args": ["scripts/redeploy.sh", "${workspaceFolder}", "polarion", "custom"],
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": []
		},
		// ── Optional ─────────────────────────────────────────────────────────
		{
			// Wie Logs, aber filtert auf ERROR/Exception – nützlich bei der
			// Fehlersuche ohne den vollen Log-Strom.
			"label": "Polarion: Error Logs",
			"type": "shell",
			"command": "bash",
			"args": ["scripts/polarionctl.sh", "errors"],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "new"
			},
			"isBackground": true,
			"problemMatcher": []
		},
		{
			// Führt nur den Preflight (Require-Bundle-Prüfung) aus – deployt
			// nichts. Sinnvoll um Abhängigkeitsfehler vor dem Deploy zu erkennen.
			"label": "Polarion: Redeploy Preflight",
			"type": "shell",
			"command": "bash",
			"args": ["scripts/redeploy.sh", "${file}", "polarion", "custom"],
			"options": {
				"env": { "POLARION_REDEPLOY_PREFLIGHT_ONLY": "true" }
			},
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": []
		}
	]
}
