{
	// -------------------------------------------------------------------------
	// Polarion Developer Tasks
	// -------------------------------------------------------------------------
	// Container-management tasks (Build Image, Start, Stop) live in
	// polarion-docker.code-workspace.  Open that file in VS Code
	// (File > Open Workspace from File…) to get both task groups merged
	// in the task picker.
	// -------------------------------------------------------------------------
	"version": "2.0.0",
	"options": {
		"env": {
			"POLARION_CONTAINER_NAME": "polarion",
			"POLARION_EXTENSION_NAME": "custom",
			"POLARION_IMAGE": "polarion:local",
			"POLARION_HTTP_PORT": "80",
			"POLARION_DB_PORT": "5433",
			"POLARION_JDWP_PORT": "5005",
			"POLARION_BIND_HOST": "0.0.0.0",
			"POLARION_JAVA_OPTS": "-Xmx3g -Xms3g",
			"POLARION_JDWP_ENABLED": "true",
			"POLARION_PLATFORM": "linux/amd64",
			"POLARION_CONTAINER_CPUS": "8",
			"POLARION_CONTAINER_MEMORY": "4g",
			"POLARION_BUILDER_CPUS": "8",
			"POLARION_BUILDER_MEMORY": "8g",
			"POLARION_REDEPLOY_SEARCH_DEPTH": "1",
			"POLARION_DATA_VOLUME": "polarion_repo",
			"POLARION_EXTENSIONS_VOLUME": "polarion_extensions"
		},
		"cwd": "${workspaceFolder}"
	},
	"tasks": [
		// -- Core tasks -------------------------------------------------------
		{
			"label": "Polarion: Logs",
			"detail": "Stream the Polarion application log live from the running container.",
			"type": "shell",
			"command": "bash",
			"args": ["scripts/polarionctl.sh", "logs"],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "new"
			},
			"problemMatcher": []
		},
		{
			"label": "Polarion: Redeploy Single",
			"detail": "Build the plugin of the currently active file (Maven) and hot-deploy it into the running container, then restart the Polarion service.",
			"type": "shell",
			"command": "bash",
			"args": ["scripts/redeploy.sh", "${file}", "polarion", "custom"],
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": []
		},
		{
			"label": "Polarion: Redeploy All",
			"detail": "Build and deploy all plugin projects found in the workspace (all biz.avasis.polarion.* projects below workspaceFolder), then restart the Polarion service.",
			"type": "shell",
			"command": "bash",
			"args": ["scripts/redeploy.sh", "${workspaceFolder}", "polarion", "custom"],
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": []
		},
		// -- Optional tasks ---------------------------------------------------
		{
			"label": "Polarion: Error Logs",
			"detail": "Stream only ERROR / Exception lines from the Polarion log — less noise than the full log stream. Useful for focused error investigation.",
			"type": "shell",
			"command": "bash",
			"args": ["scripts/polarionctl.sh", "errors"],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "new"
			},
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Polarion: Redeploy Preflight",
			"detail": "Validate all Require-Bundle dependencies of the active file's plugin without stopping Polarion or copying any files. Run this before a redeploy to catch missing bundle errors early.",
			"type": "shell",
			"command": "bash",
			"args": ["scripts/redeploy.sh", "${file}", "polarion", "custom"],
			"options": {
				"env": { "POLARION_REDEPLOY_PREFLIGHT_ONLY": "true" }
			},
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": []
		}
	]
}
